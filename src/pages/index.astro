---

<Layout>
  <div class="flex flex-col gap-6">
    <p class="text-sm">
      London-based Brazilian obsessed with UI for a decade. Working as a
      Software Engineer for half that time. I love Raycast, TailwindCSS, DJing,
      playing football, and creating pretty websites.
    </p>
    <div
      class="divide-y divide-zinc-400 overflow-hidden rounded ring-1 ring-zinc-400 dark:divide-zinc-500 dark:ring-zinc-500"
    >
      {
        externalLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            class="group flex items-center justify-between p-4 transition-transform sm:hover:bg-zinc-100 sm:dark:hover:bg-zinc-800"
          >
            <span class="flex items-center gap-4">
              <Fragment set:html={link.icon} /> {link.name}
              <span class="text-zinc-500 opacity-0 transition-transform max-sm:hidden sm:group-hover:opacity-100 dark:text-zinc-400">
                {link.description}
              </span>
            </span>
            <ArrowUpRight
              class="size-5 shrink-0 text-zinc-800 transition-transform sm:group-hover:rotate-45 dark:text-zinc-200"
              stroke-width={1.4}
            />
          </a>
        ))
      }
    </div>
    <div
      class="flex justify-center gap-6 max-sm:flex-col-reverse sm:justify-between"
    >
      <div class="flex flex-col justify-center gap-4 max-sm:items-center">
        <button
          id="copy-email"
          type="button"
          aria-label="Copy email"
          class="group -m-8 flex items-center gap-3 p-8 text-zinc-800 transition-transform dark:text-zinc-200"
        >
          lukeberrypi@gmail.com
          <span class="inline-flex items-center gap-3">
            <Copy data-copy-icon class="size-4" stroke-width={1.4} />
            <Check data-check-icon class="hidden size-4" stroke-width={1.4} />
          </span>
        </button>
        <span
          class="-mt-2 inline-flex w-fit items-center gap-1 rounded-full bg-green-100 px-2 py-0.5 text-sm text-green-600 ring-1 ring-green-500 dark:bg-transparent dark:text-emerald-500 dark:ring-emerald-500"
        >
          <div class="size-2 animate-pulse rounded-full bg-green-500 dark:bg-emerald-500"></div>
          Online
        </span>
      </div>
      <div class="flex flex-col gap-2">
        <a
          href="/luke-berry-cv.pdf"
          download="Luke-Berry-CV.pdf"
          class="flex flex-row items-center justify-center gap-3 rounded bg-sky-300 p-4 text-sky-800 ring-1 ring-sky-500 transition-transform sm:hover:bg-sky-400 dark:bg-inherit dark:text-sky-500 dark:ring-sky-500 sm:sm:dark:hover:bg-zinc-800"
        >
          <span class="text-nowrap">Download my CV</span>
          <Download class="size-5 max-sm:hidden" stroke-width={1.4} />
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const email = "lukeberrypi@gmail.com";
  let resetTimeout: ReturnType<typeof setTimeout> | undefined;

  async function copyToClipboard(text: string) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.style.position = "fixed";
      textarea.style.opacity = "0";
      document.body.appendChild(textarea);
      textarea.select();
      const success = document.execCommand("copy");
      document.body.removeChild(textarea);
      return success;
    }
  }

  // Delegated so it keeps working when navigating back to the home page via a
  // view transition, which recreates the #copy-email button.
  document.addEventListener("click", async (event) => {
    if (!(event.target instanceof Element)) return;
    const button = event.target.closest("#copy-email");
    if (!button) return;

    const copied = await copyToClipboard(email);
    if (!copied) return;

    const copyIcon = button.querySelector("[data-copy-icon]");
    const checkIcon = button.querySelector("[data-check-icon]");
    copyIcon?.classList.add("hidden");
    checkIcon?.classList.remove("hidden");
    clearTimeout(resetTimeout);
    resetTimeout = setTimeout(() => {
      checkIcon?.classList.add("hidden");
      copyIcon?.classList.remove("hidden");
    }, 3000);
  });
</script>
