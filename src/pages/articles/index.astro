---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { formatShort } from "../../lib/date";

const articles = (await getCollection("articles")).sort((a, b) =>
  a.data.date < b.data.date ? 1 : -1,
);
---

<Layout>
  <div>
    <h1 class="mb-16 mt-4 text-center text-5xl max-sm:text-4xl">Articles</h1>

    <section
      class="flex flex-col divide-y divide-zinc-400 overflow-hidden rounded ring-1 ring-zinc-400 dark:divide-zinc-500 dark:ring-zinc-500"
    >
      {
        articles.map((article) => (
          <a
            class="flex items-center justify-between px-4 py-2 transition-transform sm:p-4 sm:hover:bg-zinc-100 sm:dark:hover:bg-zinc-800"
            href={`/articles/${article.id}`}
          >
            <div class="flex gap-1 gap-x-2 max-sm:flex-col sm:items-center">
              {article.data.title}{" "}
              <span class="flex gap-2 text-sm text-zinc-500 dark:text-zinc-400">
                {article.data.tags?.map((tag) => <span>#{tag}</span>)}
              </span>
            </div>
            <span class="text-zinc-500 max-sm:text-sm dark:text-zinc-400">
              {formatShort(article.data.date)}
            </span>
          </a>
        ))
      }
    </section>
  </div>
</Layout>
