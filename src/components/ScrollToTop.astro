---
import ArrowUp from "@lucide/astro/icons/arrow-up";
---

<button
  data-scroll-top
  aria-label="Scroll to top"
  class="opacity-0 fixed z-10 items-center gap-2 rounded bg-zinc-50 py-2 pl-4 pr-3 ring-1 ring-zinc-400 transition-transform sm:right-8 sm:top-8 sm:flex sm:hover:bg-zinc-100 dark:bg-zinc-900 dark:ring-zinc-500 sm:hover:dark:bg-zinc-800"
>
  Back to top
  <ArrowUp class="size-4" />
</button>
<button
  data-scroll-top
  aria-label="Scroll to top"
  class="opacity-0 fixed z-10 items-center gap-2 rounded bg-zinc-50 p-3 ring-1 ring-zinc-400 transition-transform max-sm:bottom-6 max-sm:right-6 max-sm:flex sm:hover:bg-zinc-100 dark:bg-zinc-900 dark:ring-zinc-500 sm:hover:dark:bg-zinc-800"
>
  <ArrowUp class="size-5" />
</button>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-scroll-top]");

  const updateVisibility = () => {
    const visible = window.scrollY > 400;
    buttons.forEach((button) => {
      button.classList.toggle("opacity-100", visible);
      button.classList.toggle("opacity-0", !visible);
    });
  };

  buttons.forEach((button) =>
    button.addEventListener("click", () => window.scrollTo({ top: 0 })),
  );

  window.addEventListener("scroll", updateVisibility);
  updateVisibility();
</script>
